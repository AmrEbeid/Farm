# Farm OS — PRODUCTION env template (set these in the Vercel project, not in the repo).
# Copy values from the dedicated, NON-Zeal Supabase project (see OWNER-DECISIONS §1).
# Never commit real values. The service-role key is server-only and bypasses RLS.

# Public — exposed to the browser (anon key is RLS-scoped; safe).
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-project-settings>

# Server-only — NEVER prefix with NEXT_PUBLIC_, never expose to the client.
# Used solely by lib/supabase/admin.ts (server-side admin/seed paths).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-project-settings>

# NOTE: the dev /api/dev/seed-auth route self-disables when the Supabase URL is not
# local (isLocal() → 403), so it is inert in production. Real users sign in via phone-OTP
# (configure Supabase Auth → Phone provider → Twilio; see DEPLOY-RUNBOOK.md).
