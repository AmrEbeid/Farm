# EditorConfig — https://editorconfig.org
# Settings derived from the repo's existing files (no reformatting implied).
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown uses trailing spaces for hard line breaks — don't trim them.
[*.md]
trim_trailing_whitespace = false
